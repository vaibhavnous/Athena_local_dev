# Copy to .env and fill with your own values.
# Do NOT commit the real .env file.

# Local dev vector search uses Pinecone plus Azure/OpenAI embeddings.
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=
# PINECONE_ENVIRONMENT=
# PINECONE_SCHEMA_INDEX_NAME=
# PINECONE_KNOWLEDGE_BASE_INDEX_NAME=knowledgebase

# Optional domain knowledge base. Runtime flag defaults off.
ATHENA_USE_DOMAIN_KB=false
ATHENA_KB_ID=PC_Insurance_V1
ATHENA_DOMAIN_PROFILE=Insurance
ATHENA_KB_TOP_K_ENRICHMENT=8
ATHENA_KB_TOP_K_GOLD=10
ATHENA_KB_MAX_CHARS_ENRICHMENT=4000
ATHENA_KB_MAX_CHARS_GOLD=5000

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_MODEL=gpt-4.1
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-12-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional app settings
ATHENA_DEMO_MODE=false
ATHENA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ATHENA_BLOCK_EMBEDDINGS=false
ATHENA_ENABLE_EMBEDDINGS=true
ATHENA_PRELOAD_EMBEDDINGS=false
ATHENA_ALLOW_LOCAL_EMBEDDING_FALLBACK=false
ATHENA_EMBEDDING_PRELOAD_REQUIRED=false
HF_HOME=
SENTENCE_TRANSFORMERS_HOME=
DEV_MODE=false
LOGTAIL_TOKEN=
ATHENA_APP_DATA_DIR=/home/site/data
ATHENA_GENERATED_CODE_DIR=
ATHENA_UPLOAD_DIR=
ATHENA_PIPELINE_LOG_FILE=
ATHENA_MARK_INTERRUPTED_RUNS_ON_STARTUP=true
ATHENA_INTERRUPTED_RUN_RECOVERY_LIMIT=50
ATHENA_BACKGROUND_WORKERS=1
BRONZE_MAX_WORKERS=3
SILVER_MAX_WORKERS=3
COLUMN_PROFILING_MAX_WORKERS=3
GUNICORN_TIMEOUT_SECONDS=600

# Optional compliance assessment backend. Enabled per run with compliance_enabled=true.
COMPLIANCE_BACKEND_URL=https://astra-compliance-hhgxb8hshua7ftdc.southindia-01.azurewebsites.net
COMPLIANCE_REQUEST_TIMEOUT_SECONDS=300
COMPLIANCE_MAX_METADATA_COLUMNS=50
COMPLIANCE_BACKGROUND_WORKERS=2
COMPLIANCE_DOMAIN=Insurance
COMPLIANCE_COUNTRIES=US

# Azure SQL (pipeline DB where ai_store / kpi_checkpoints / hitl_review_queue live)
AZURE_SQL_HOST=
AZURE_SQL_PORT=1433
AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server
AZURE_SQL_CONNECTION_TIMEOUT=5

# Connection retry policy (keep small for local dev)
ATHENA_SQL_CONNECT_RETRIES=1
ATHENA_SQL_CONNECT_RETRY_DELAY_SECONDS=1
# Minimum visibility for automatic phase 1-2 stages. Reviews and column profiling are excluded; 0 disables it.
ATHENA_MIN_STAGE_RUNTIME_SECONDS=10
ATHENA_RUNS_ENDPOINT_TIMEOUT_SECONDS=5
ATHENA_RUNS_LIST_LIMIT=25
ATHENA_SQL_QUERY_TIMEOUT_SECONDS=5
AZURE_SQL_ENCRYPT=yes
AZURE_SQL_TRUST_SERVER_CERTIFICATE=no
AZURE_SQL_CONNECTION_TIMEOUT=30
ATHENA_SQL_TCP_PROBE_TIMEOUT_SECONDS=10
ATHENA_SQL_TCP_PROBE_ENABLED=false
ATHENA_SQL_FAIL_FAST_ON_TCP_PROBE=false
AZURE_SQL_PIPELINE_DATABASE=
AZURE_SQL_PIPELINE_SCHEMA=metadata
AZURE_SQL_USERNAME=
AZURE_SQL_PASSWORD=

# Azure SQL (source/client DB that contains the business tables)
AZURE_SQL_SOURCE_HOST=
AZURE_SQL_SOURCE_DATABASE=
AZURE_SQL_SOURCE_SCHEMA=dbo
AZURE_SQL_SOURCE_USERNAME=
AZURE_SQL_SOURCE_PASSWORD=

# Snowflake Bronze execution (off by default; generation still works without these)
ATHENA_EXECUTE_SNOWFLAKE_BRONZE=false
ATHENA_EXECUTE_SNOWFLAKE_SILVER=false
ATHENA_EXECUTE_SNOWFLAKE_GOLD=false
ATHENA_SNOWFLAKE_BRONZE_LOAD_SOURCE=false
ATHENA_SNOWFLAKE_BRONZE_SOURCE_MODE=azure_sql
# Optional safety filter for Snowflake Bronze generation.
# Leave unset or use "*" to generate scripts for the pipeline-selected tables.
ATHENA_SNOWFLAKE_BRONZE_TABLE_ALLOWLIST=*
SNOWFLAKE_BRONZE_CATALOG=ATHENA_DB
SNOWFLAKE_BRONZE_SCHEMA=BRONZE
SNOWFLAKE_SILVER_CATALOG=ATHENA_DB
SNOWFLAKE_SILVER_SCHEMA=SILVER
SNOWFLAKE_GOLD_CATALOG=ATHENA_DB
SNOWFLAKE_GOLD_SCHEMA=GOLD
ATHENA_GOLD_MAX_SOURCE_TABLES=3
ATHENA_GOLD_MAX_DIMENSION_TABLES=2
ATHENA_SNOWFLAKE_BRONZE_SOURCE_LOAD_LIMIT=0
ATHENA_SNOWFLAKE_BRONZE_BATCH_SIZE=1000
ATHENA_SNOWFLAKE_ADLS_INSERT_BATCH_SIZE=1000
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=
SNOWFLAKE_ADLS_INTEGRATION=ADLS_INSURANCE_INT
SNOWFLAKE_ADLS_STAGE_DB=ATHENA_DB
SNOWFLAKE_ADLS_STAGE_SCHEMA=BRONZE
SNOWFLAKE_ADLS_STAGE_NAME=ADLS_INSURANCE_STAGE
SNOWFLAKE_ADLS_STAGE_URL=azure://atheastorage.blob.core.windows.net/athena/Insurance/
SNOWFLAKE_ADLS_FILE_FORMAT=ADLS_CSV_FORMAT

# ADLS Python/service-principal source mode.
# Use ATHENA_SNOWFLAKE_BRONZE_SOURCE_MODE=adls_python to load files through backend Python.
ADLS_ACCOUNT_URL=https://atheastorage.dfs.core.windows.net
ADLS_FILE_SYSTEM=athena
ADLS_SOURCE_ROOT=evention/vendor1/machine1
ADLS_PREFIX=evention/vendor1/machine1
ADLS_VENDOR_ROOT=evention/vendor1/machine1
ADLS_VENDOR_NAME=Vendor1
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Optional LLM-assisted Silver/Gold code generation. Outputs are validated and
# fall back to deterministic generators when disabled or unavailable.
ATHENA_SILVER_USE_LLM=false
ATHENA_GOLD_USE_LLM=false
ATHENA_SILVER_LLM_PROVIDER=azure_openai
ATHENA_GOLD_LLM_PROVIDER=azure_openai
